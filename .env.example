# Site (JSON array of allowed origins for CORS and cookie rules)
SITE_URL=["http://localhost:3000"]

# Auth
APP_JWT_SECRET=

# AI — system keys (optional if all users use BYOK)
OPENAI_API_KEY=
GEMINI_API_KEY=

# AI — encrypt user BYOK keys in HttpOnly cookies (long random string; hashed with SHA-256 for AES-GCM).
# Generate e.g.: openssl rand -base64 32
AI_COOKIE_SECRET=
